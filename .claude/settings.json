{
  "permissions": {
    "allow": [],
    "deny": [],
    "defaultMode": "bypassPermissions"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/gh-auth-guard.sh"
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -c \"import sys,json; d=json.load(sys.stdin); sys.exit(2) if not d.get('tool_input',{}).get('run_in_background') else sys.exit(0)\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/gh-audit-log.sh"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.session_id' | { read -r sid; touch \"/tmp/claude-subagent-${sid}-started\"; }"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.session_id' | { read -r sid; if [ ! -f \"/tmp/claude-subagent-${sid}-closed\" ]; then echo '{\"systemMessage\":\"WARNING: Subagent closed without running /end-subagent-session. Run the closing protocol manually.\"}'; fi; rm -f \"/tmp/claude-subagent-${sid}-started\" \"/tmp/claude-subagent-${sid}-closed\"; }"
          }
        ]
      }
    ]
  }
}
