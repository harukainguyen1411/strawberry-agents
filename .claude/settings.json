{
  "permissions": {
    "allow": [
      "Edit",
      "Write",
      "Read",
      "Grep",
      "Glob",
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(bash scripts/*)",
      "Bash(python3 *)",
      "Bash(cat *)",
      "Bash(ls *)",
      "Bash(echo *)",
      "Bash(mkdir *)",
      "Bash(touch *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(find * -type *)",
      "Bash(jq *)",
      "Bash(pwd)",
      "Bash(test *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(sed *)",
      "Bash(awk *)",
      "Bash(npm *)",
      "Bash(pnpm *)",
      "Bash(node *)",
      "WebFetch",
      "WebSearch",
      "Agent",
      "Skill",
      "Task*"
    ],
    "deny": [],
    "defaultMode": "auto"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/hooks/sessionstart-coordinator-identity.sh"
          },
          {
            "type": "command",
            "command": "bash scripts/hooks/inbox-watch-bootstrap.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/gh-auth-guard.sh"
          },
          {
            "type": "command",
            "command": "bash scripts/hooks/pretooluse-plan-lifecycle-guard.sh"
          },
          {
            "type": "command",
            "command": "bash scripts/hooks/pretooluse-subagent-identity.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/hooks/pretooluse-plan-lifecycle-guard.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/hooks/pretooluse-inbox-write-guard.sh"
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -c \"import sys,json; d=json.load(sys.stdin); sys.exit(2) if not d.get('tool_input',{}).get('run_in_background') else sys.exit(0)\""
          },
          {
            "type": "command",
            "command": "bash scripts/hooks/agent-default-isolation.sh"
          },
          {
            "type": "command",
            "command": "bash scripts/hooks/agent-identity-default.sh"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/hooks/pretooluse-monitor-arming-gate.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/gh-audit-log.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/subagent-denial-probe.sh"
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '{subagent: (.tool_input.subagent_type // \"unknown\"), description: (.tool_input.description // \"unknown\")} | \"REMINDER: TaskCreate for subagent \\u2018\" + .subagent + \"\\u2019 \\u2014 \\u2018\" + .description + \"\\u2019. Set owner=\" + .subagent + \".\"' | { read -r msg; printf '{\"hookSpecificOutput\":{\"hookEventName\":\"PostToolUse\",\"additionalContext\":\"%s\"}}' \"$(echo \"$msg\" | sed 's/\"/\\\\\"/g')\"; }"
          }
        ]
      },
      {
        "matcher": "Monitor",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/hooks/posttooluse-monitor-arm-sentinel.sh"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.session_id' | { read -r sid; touch \"/tmp/claude-subagent-${sid}-started\"; }"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '(.session_id),(.agent_id)' | { read -r sid; read -r aid; if [ ! -f \"/tmp/claude-subagent-${sid}-closed\" ]; then echo '{\"systemMessage\":\"WARNING: Subagent closed without running /end-subagent-session. Run the closing protocol manually.\"}'; fi; mkdir -p \"${HOME}/.claude/strawberry-usage-cache/subagent-sentinels\" && touch \"${HOME}/.claude/strawberry-usage-cache/subagent-sentinels/${aid}\"; rm -f \"/tmp/claude-subagent-${sid}-started\" \"/tmp/claude-subagent-${sid}-closed\"; }"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "manual",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/hooks/pre-compact-gate.sh"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "code-simplifier@claude-plugins-official": true,
    "github@claude-plugins-official": true
  },
  "agent": "Evelynn"
}
