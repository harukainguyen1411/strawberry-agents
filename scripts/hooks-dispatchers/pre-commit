#!/bin/sh
# strawberry-managed dispatcher for pre-commit
# Writes to scripts/hooks-dispatchers/pre-commit (tracked in-repo).
# Re-run install-hooks.sh to regenerate.
set -e
REPO_ROOT="$(git rev-parse --show-toplevel)"
HOOKS_SRC="$REPO_ROOT/scripts/hooks"
_rc=0
for _sub in $(ls "$HOOKS_SRC"/*.sh 2>/dev/null | sort); do
  _base=$(basename "$_sub")
  case "$_base" in
    pre-commit-*.sh)
      "$_sub" "$@" || _rc=$?
      ;;
  esac
done
exit $_rc
