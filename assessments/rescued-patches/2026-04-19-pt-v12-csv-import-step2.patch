@@ -1,9 +1,58 @@
 /**
- * useImportCsv — stub for V0.12 xfail.
- * Full implementation in V0.12 implementation commit.
+ * useImportCsv — composable to call the importCsv HTTPS callable (V0.8).
+ *
+ * Wraps the Firebase callable `importCsv` with reactive loading/error state.
+ * On success returns { tradesAdded, tradesSkipped, positionsWritten, errors }.
+ *
  * Refs V0.12
  */
 
+import { ref } from 'vue'
+import { getFunctions, httpsCallable } from 'firebase/functions'
+import { app } from '@/firebase/config'
+
+export interface ImportResult {
+  tradesAdded: number
+  tradesSkipped: number
+  positionsWritten: number
+  errors: Array<{ row: number; reason: string }>
+}
+
+export interface ImportPayload {
+  source: 'T212' | 'IB'
+  csvText: string
+}
+
 export function useImportCsv() {
-  throw new Error('not implemented — V0.12')
+  const loading = ref(false)
+  const error = ref<string | null>(null)
+  const result = ref<ImportResult | null>(null)
+
+  const functions = getFunctions(app)
+  const callable = httpsCallable<ImportPayload, ImportResult>(functions, 'importCsv')
+
+  async function importCsv(payload: ImportPayload): Promise<ImportResult | null> {
+    loading.value = true
+    error.value = null
+    result.value = null
+
+    try {
+      const response = await callable(payload)
+      result.value = response.data
+      return response.data
+    } catch (err) {
+      error.value = err instanceof Error ? err.message : String(err)
+      return null
+    } finally {
+      loading.value = false
+    }
+  }
+
+  function reset() {
+    loading.value = false
+    error.value = null
+    result.value = null
+  }
+
+  return { importCsv, loading, error, result, reset }
 }
