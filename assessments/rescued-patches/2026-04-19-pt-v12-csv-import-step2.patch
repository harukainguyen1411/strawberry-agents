 <template>
-  <!-- Toast stub — V0.12 xfail placeholder -->
-  <div></div>
+  <!--
+    Toast — global notification with auto-dismiss.
+    Props:
+      show      - controlled visibility
+      message   - text to display
+      duration  - auto-dismiss delay in ms (default 5000)
+      onRetry   - optional retry callback
+    Emits:
+      dismiss   - fired when toast hides (auto or manual)
+    Refs V0.12
+  -->
+  <Teleport to="body">
+    <Transition name="toast-fade">
+      <div
+        v-if="show"
+        data-testid="toast"
+        role="status"
+        aria-live="polite"
+        class="fixed z-[200] flex items-center gap-3 px-4 py-3 rounded-xl shadow-lg text-sm"
+        :class="position === 'bottom' ? 'bottom-6 left-1/2 -translate-x-1/2' : 'top-6 right-6'"
+        style="
+          background: var(--surface-hi);
+          border: 1px solid var(--border-hi);
+          color: var(--text);
+          min-width: 240px;
+          max-width: 360px;
+        "
+      >
+        <span class="flex-1">{{ message }}</span>
+        <div class="flex items-center gap-2 flex-shrink-0">
+          <button
+            v-if="onRetry"
+            data-testid="toast-retry-btn"
+            type="button"
+            class="text-xs font-medium underline"
+            style="color: var(--accent-soft);"
+            @click="handleRetry"
+          >
+            Retry
+          </button>
+          <button
+            type="button"
+            class="flex items-center justify-center w-5 h-5 rounded opacity-60 hover:opacity-100"
+            style="color: var(--muted);"
+            aria-label="Dismiss notification"
+            @click="dismiss"
+          >
+            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
+              <line x1="18" y1="6" x2="6" y2="18" />
+              <line x1="6" y1="6" x2="18" y2="18" />
+            </svg>
+          </button>
+        </div>
+      </div>
+    </Transition>
+  </Teleport>
 </template>
+
 <script setup lang="ts">
-defineProps<{ message?: string; show?: boolean; onRetry?: () => void }>()
+import { watch, onUnmounted } from 'vue'
+
+const props = withDefaults(defineProps<{
+  show: boolean
+  message: string
+  duration?: number
+  onRetry?: () => void
+  position?: 'bottom' | 'top-right'
+}>(), {
+  duration: 5000,
+  position: 'top-right',
+})
+
+const emit = defineEmits<{
+  dismiss: []
+}>()
+
+let timer: ReturnType<typeof setTimeout> | null = null
+
+watch(() => props.show, (visible) => {
+  if (timer) {
+    clearTimeout(timer)
+    timer = null
+  }
+  if (visible && props.duration > 0) {
+    timer = setTimeout(dismiss, props.duration)
+  }
+}, { immediate: true })
+
+onUnmounted(() => {
+  if (timer) clearTimeout(timer)
+})
+
+function dismiss() {
+  if (timer) {
+    clearTimeout(timer)
+    timer = null
+  }
+  emit('dismiss')
+}
+
+function handleRetry() {
+  dismiss()
+  props.onRetry?.()
+}
 </script>
+
+<style scoped>
+.toast-fade-enter-active,
+.toast-fade-leave-active {
+  transition: opacity 0.2s ease, transform 0.2s ease;
+}
+.toast-fade-enter-from,
+.toast-fade-leave-to {
+  opacity: 0;
+  transform: translateY(8px);
+}
+</style>
