# OS
.DS_Store

# Secrets and credentials
.env
.env.*
*.key
*.pem
credentials.json
*-credentials.json
*-oauth-keys.json
secrets/*
!secrets/encrypted/
!secrets/recipients.txt
!secrets/README.md
secrets/encrypted/*
!secrets/encrypted/*.age
!secrets/encrypted/*.age.sha256
!secrets/work/
secrets/work/*
!secrets/work/encrypted/
!secrets/work/REVOCATION.md
secrets/work/encrypted/*
!secrets/work/encrypted/*.age
!secrets/work/encrypted/*.age.sha256
!secrets/work/encrypted/.gitkeep
secrets/work/runtime/

# Agent-local settings (contains API keys)
settings.local.json

# Agent runtime (managed by MCP, not version-tracked)
usage/
*.db

# Transcripts (large, auto-generated at project root — NOT agent transcripts)
transcripts/

# Agent cleaned-transcript archives ARE committed (see /end-session skill)
!agents/*/transcripts/
!agents/*/transcripts/*.md
!agents/*/transcripts/.gitkeep

# Node / Python
node_modules/
__pycache__/
*.pyc
.venv/
agents/health/*.json

# Operational ephemera (live in ~/.strawberry/ops/, not in git)
agents/*/inbox/
agents/conversations/
agents/inbox-queue/

# Agent session ephemera (high-churn, no git value)
agents/*/journal/
agents/*/memory/last-session.md
agents/evelynn/memory/.consolidate.lock
.orianna-sign-stderr.tmp

# Telegram bridge state
.telegram-offset


# Remember plugin runtime state
.remember/

# discord-relay runtime state
apps/discord-relay/var/

# Build output and runtime logs for local workers
apps/discord-relay/dist/
apps/discord-relay/logs/
apps/coder-worker/dist/
apps/coder-worker/logs/
apps/deploy-webhook/dist/
apps/deploy-webhook/logs/
dashboards/server/dist/
dashboards/test-dashboard/dist/

# Retrospection dashboard emitted static site (gitignored; regenerated by retro:render)
# Use file-pattern exclusion (not directory) so negation for .gitkeep works.
tools/retro/dist/**
!tools/retro/dist/data/
!tools/retro/dist/data/.gitkeep

# Composite deploy assembly directory (gitignored — assembled at deploy time)
deploy/
!scripts/deploy/

# Build artifacts
.turbo/
**/.turbo/
.firebase/
.playwright-mcp/
apps/functions/lib/

# Claude session sentinels
.claude/*.sentinel

# Claude agent worktrees
.claude/worktrees/

# User worktrees
.worktrees/

# Stray logs
firebase-debug.log

# Per-checkout coordinator identity hint (written by /pre-compact-save, consumed by sessionstart hook)
.coordinator-identity

# Per-checkout precompact opt-out marker (touched by Duong to skip /pre-compact-save gate)
.no-precompact-save

# Local scheduler lock
.claude/scheduled_tasks.lock

# Playwright/Akali QA runtime artifacts (logs + page snapshots; reports remain tracked)
assessments/qa-artifacts/
