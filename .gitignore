# OS
.DS_Store

# Secrets and credentials
.env
.env.*
*.key
*.pem
credentials.json
*-credentials.json
*-oauth-keys.json
secrets/

# Agent-local settings (contains API keys)
settings.local.json

# Agent runtime (managed by MCP, not version-tracked)
usage/
*.db

# Transcripts (large, auto-generated)
transcripts/

# Node / Python
node_modules/
__pycache__/
*.pyc
.venv/
agents/health/*.json

# Operational ephemera (live in ~/.strawberry/ops/, not in git)
agents/*/inbox/
agents/conversations/
agents/inbox-queue/

# Agent session ephemera (high-churn, no git value)
agents/*/journal/
agents/*/memory/last-session.md

# Telegram bridge state
.telegram-offset

strawberry
strawberry.pub